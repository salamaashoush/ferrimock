{
  "name": "@mockpit/playwright",
  "version": "0.1.0",
  "description": "Playwright adapter for mockpit -- fixtures that wire the mock engine into page.route()",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
