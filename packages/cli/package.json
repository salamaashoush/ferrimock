{
  "name": "@mockpit/cli",
  "version": "0.1.0",
  "description": "CLI for the mockpit HTTP mocking engine",
  "type": "module",
  "bin": {
    "mockpit": "./bin/mockpit.mjs"
  },
  "main": "./dist/cli.mjs",
  "types": "./dist/cli.d.mts",
  "exports": {
